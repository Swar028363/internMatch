# InternMatch backend environment variables 

# Database
# DATABASE_URL=sqlite:///./internMatch.db

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# JWT
# JWT_EXPIRE_SECONDS=3600

# OTP expiry seconds
OTP_EXPIRY_SECONDS=600

# Using gmail to send the otp form
GMAIL_USER=your gmail

# go to you manage gmail account and search app password and make a new password for this app and paste it here
GMAIL_APP_PASS=the app password

# File uploads
# UPLOAD_DIR=./uploads

