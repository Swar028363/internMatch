# InternMatch backend environment variables 

# Database
# DATABASE_URL=sqlite:///./internMatch.db

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# JWT
# JWT_EXPIRE_SECONDS=3600

# OTP expiry seconds
OTP_EXPIRY_SECONDS=600

# File uploads
# UPLOAD_DIR=./uploads

# Resend email — get your API key at resend.com (free tier: 3000 emails/month)
RESEND_API_KEY=YOUR_API_KEY

# From address — use onboarding@resend.dev for testing (no domain needed)
# For production use your own verified domain email
FROM_EMAIL=onboarding@resend.dev
